-# Student claim-verification exercise (issue #6910). All visible wording is a
-# descriptive COPY stub, not draft content: each bracketed note states the
-# message's purpose so an operator can write the real text. The claim and the
-# source values are real data. The design focuses attention on those two.
.container.narrow.claim-verification-exercise
  .claim-verification-exercise__intro
    %h1 [COPY — page heading: names this "check whether the cited source supports the claim" exercise]
    %p
      [COPY — intro, 1–2 sentences: the student reads the cited source and decides
      whether it actually supports the claim shown, then records what they find in
      their own Wikipedia sandbox]

  - if @claim
    %section.claim-verification-exercise__claim
      %h2.claim-verification-exercise__label [COPY — label for the claim, eg "The claim to check"]
      %blockquote.claim-verification-exercise__claim-text= @claim.sentence
      - if claim_article_url(@claim)
        %p.claim-verification-exercise__article-link
          = link_to '[COPY — link text, eg "Find this in the Wikipedia article"]',
              claim_article_url(@claim), target: '_blank', rel: 'noopener'
      - if @claim.context.present? && @claim.context != @claim.sentence
        %details.claim-verification-exercise__context
          %summary [COPY — toggle label, eg "Show the surrounding paragraph"]
          %p= @claim.context

    %section.claim-verification-exercise__source
      %h2.claim-verification-exercise__label [COPY — label for the source, eg "The source it cites — does it support the claim?"]
      - if @claim.cite_text.present?
        %p.claim-verification-exercise__citation= @claim.cite_text
      - if claim_source_url(@claim)
        = link_to '[COPY — link text, eg "Open the cited source"]',
            claim_source_url(@claim),
            class: 'button dark claim-verification-exercise__source-link',
            target: '_blank', rel: 'noopener'
      - else
        %p.claim-verification-exercise__no-source
          [COPY — note shown when the citation has no online source the student can open]

    %section.claim-verification-exercise__sandbox
      %p
        [COPY — instructions: open your sandbox (it will be preloaded with a
        worksheet) and write whether the source supports the claim, with reasoning]
      = link_to '[COPY — button label, eg "Start in your sandbox"]',
          claim_verification_sandbox_url(@course, current_user),
          class: 'button border claim-verification-exercise__sandbox-link',
          target: '_blank', rel: 'noopener'

    .claim-verification-exercise__switch
      = button_to '[COPY — button label, eg "Show me a different claim"]',
          "/courses/#{@course.slug}/verify_claim/switch",
          class: 'button claim-verification-exercise__switch-button'
  - else
    %p.claim-verification-exercise__empty
      [COPY — message shown when no claim is available to assign yet]
