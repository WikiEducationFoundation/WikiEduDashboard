- # In-Canvas drill-down for the rolled-up "Wikipedia trainings" column.
- # Instructors get what the roll-up covers plus a per-student
- # completed-count roster (same numbers the grade sync pushes); a student
- # gets the same per-module table as the Students-tab details drawer —
- # every assigned training in due-date order, its due date, their status,
- # each linked straight to the training module on the Dashboard.
.lti-iframe__drilldown
  = render 'lti_launch/drilldown_header', title: @context.title, course: @context.course
  - if @context.instructor?
    .lti-iframe__description
      %ul.lti-trainings-list
        - @context.training_module_names.each do |name|
          %li= name
    - roster = @context.roster
    - if roster.empty?
      %p.lti-iframe__empty= t('lti.assignment_view.roster.empty')
    - else
      %table.lti-assignment-roster
        %thead
          %tr
            %th= t('lti.assignment_view.roster.student')
            %th= t('lti.assignment_view.roster.status')
        %tbody
          - roster.each do |row|
            %tr
              %td= row.name
              %td
                %span.lti-status{ class: row.done? ? 'lti-status--done' : 'lti-status--pending' }
                  = t('lti.assignment_view.trainings.progress',
                      completed: row.completed_count, total: row.total_count)
  - else
    - row = @context.student_panel
    .lti-iframe__panel
      %span.lti-status{ class: row.done? ? 'lti-status--done' : 'lti-status--pending' }
        = t('lti.assignment_view.trainings.progress',
            completed: row.completed_count, total: row.total_count)
      %table.lti-assignment-roster
        %thead
          %tr
            %th= t('lti.assignment_view.trainings.module')
            %th= t('lti.assignment_view.trainings.due_date')
            %th= t('lti.assignment_view.roster.status')
        %tbody
          - @context.viewer_training_rows.each do |training|
            %tr
              %td
                = link_to training.name, training.training_url,
                          target: '_blank', rel: 'noopener'
              %td= training.due_date&.strftime('%b %-d, %Y')
              %td
                %span.lti-status{ class: training.completed? ? 'lti-status--done' : 'lti-status--pending' }
                  = training.status
