- # Shown when an assignment_view launch can't be matched to a Block-backed
- # line item — e.g. the lumped "Wikipedia trainings" column, a manually
- # created Canvas assignment, or a column whose mapping isn't captured yet.
.container.narrow
  .section-header
    %h3= t('lti.assignment_view.orphan.header')
  %p= t('lti.assignment_view.orphan.explanation')
