- row = @context.student_panel
.lti-iframe__panel
  %span.lti-status{ class: row.completed? ? 'lti-status--done' : 'lti-status--pending' }
    = row.completed? ? t('lti.assignment_view.status.completed') : t('lti.assignment_view.status.not_started')
  - if row.sandbox_url
    = link_to t('lti.assignment_view.student.your_sandbox'), row.sandbox_url,
              target: '_blank', rel: 'noopener', class: 'button dark lti-iframe__button'
