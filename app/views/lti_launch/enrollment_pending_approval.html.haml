.lti-iframe__landing
  = image_tag '/assets/images/wiki-logo.png', alt: 'Wiki Education Dashboard', class: 'lti-iframe__logo'
  %h3.lti-iframe__title= t('lti.enrollment_pending_approval.header')
  %p= t('lti.enrollment_pending_approval.explanation')
  %p= t('lti.enrollment_pending_approval.contact_hint')
  -# Re-launches in the iframe: once staff approve the course, this enrolls the
  -# student and lands them in the course without needing to know to reload.
  = link_to t('lti.check_again'), "/lti?ltik=#{CGI.escape(params[:ltik].to_s)}",
            class: 'lti-iframe__check-again'
