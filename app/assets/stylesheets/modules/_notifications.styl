.alert
  padding 20px
  text-align center
  p
    color warning
  td
    text-align left

.notification
  background-color sprout
  padding 10px
  color #fff
  text-align center
  font-weight bold
  > .container
    display flex
    align-items center
    +below(tablet)
      flex-direction column
    p
      flex 1
      margin-bottom 0
      white-space pre-line
      overflow overlay

    .button
      margin-left 20px

    a:not(.button)
      color #fff

  &.declined
    // Default green background from .notification will be used

.notice
  @extends .notification
  position relative
  z-index 9999
  width 100%
  text-align left
  background-color warning
  color #fff
  > .container
   svg
      &:focus,
      &:hover
        cursor pointer
        color smoke
        outline none

.notice--error
  @extends .notice
  text-align center

.notification--course-ended
  position sticky
  top 55px
  z-index 98
  text-align left
  margin-left calc(-50vw + 50%)
  margin-right calc(-50vw + 50%)
  margin-top -30px
  margin-bottom 30px
  width 100vw
  padding 15px 0
