.mailer-previews-header
  padding 40px 0 24px
  border-bottom 1px solid $border_lt
  margin-bottom 40px
  p
    color $text_med
    max-width 600px
    margin 0

.preview-category
  margin-bottom 48px

.preview-category__name
  font-size 1.25em
  font-weight 600
  color bayoux
  margin-bottom 16px
  padding-bottom 10px
  border-bottom 2px solid $brand_primary

.preview-table
  width 100%
  border-collapse collapse
  thead th
    font-size 0.75em
    font-weight 600
    text-transform uppercase
    letter-spacing 0.06em
    color $text_med_header
    text-align left
    padding 0 12px 8px 0
    border-bottom 1px solid $border_lt
  tbody tr
    border-bottom 1px solid $border_lt
    &:last-child
      border-bottom none
  td
    padding 7px 12px 7px 0
    vertical-align middle
  a
    color bayoux
    text-decoration none
    &:hover
      text-decoration underline

.preview-table__group-header td
  padding-top 20px
  padding-bottom 4px
  border-bottom none

.preview-group__name
  font-size 0.8em
  font-weight 600
  color $text

.preview-recipients
  font-size 0.85em
  color $text_med
  white-space nowrap
  width 1%
