// Minimal styling for the in-iframe LTI launch views. No navbar/footer.
// White background so the content sits seamlessly inside Canvas's white
// pages — these views render in Canvas iframes, often the small default
// assignment embed, so chrome and spacing stay minimal throughout.
body.lti-iframe
  background #fff
  font-family inherit

.lti-iframe__main
  display flex
  justify-content center
  align-items center
  min-height 100vh
  padding 16px

.lti-iframe__landing
  text-align center
  max-width 480px
  padding 32px 24px

.lti-iframe__logo
  display block
  margin 0 auto 32px
  max-width 260px
  max-height 120px
  width auto
  height auto

.lti-iframe__title
  font-size 18px
  font-weight normal
  margin 0 0 24px
  color #333

// Link-state notice on the anonymous landing ("not yet linked"): the
// substantive status line above the open-in-new-tab hint and button.
.lti-iframe__status
  margin 0 0 16px
  color #17212b
  font-size 15px

.lti-iframe__button
  display inline-block

// Option lists in the deep-link picker and the setup form's gradebook-layout
// chooser: one option per row (bare inline labels otherwise wrap into a
// horizontal jumble). Grid keeps the input in its own column with the label
// text — and any example/description line — aligned beside it.
.lti-deep-link-options,
.lti-granularity-options
  display flex
  flex-direction column
  gap 10px
  margin 16px 0

  label
    display grid
    grid-template-columns auto 1fr
    column-gap 8px
    align-items baseline
    cursor pointer

    p
      grid-column 2
      margin 2px 0 0

.lti-granularity-example
  color #5a6b7b
  font-size 13px

// Setup form: "Link this course" is a primary action that only makes sense
// once a course is chosen, so JS disables it until then; dim it and swap the
// cursor so the disabled state clearly reads as "not ready yet".
.lti-setup__submit[disabled]
  opacity .5
  cursor not-allowed

// Shown when the setup POST rejects the chosen course (e.g. it's already linked
// to another Canvas course). The picker normally omits such courses, so this is
// a rare fallback; make it read clearly as an error above the form.
.lti-setup__error
  margin 0 0 18px
  padding 12px 16px
  border-radius 6px
  background #fdecea
  border 1px solid #f5c6c2
  color #8a1c13

// Secondary path for instructors whose course isn't listed yet: a quiet line
// under the form pointing them to their dashboard to set one up.
.lti-setup__alt-path
  margin-top 18px
  color #5a6b7b
  font-size 13px

// Assignment_view drill-down (instructor roster / student panel) and the
// instructor status view. Top-aligned plain content, no card chrome — the
// default Canvas assignment iframe is small, and a bordered/padded card
// wastes enough space to force scrolling.
.lti-iframe__drilldown
  align-self flex-start
  width 100%
  max-width 640px
  margin 0 auto
  text-align left

.lti-iframe__drilldown-title
  margin 0 0 12px
  padding-bottom 8px
  border-bottom 2px solid #2a5db0
  font-size 18px
  color #17212b

.lti-iframe__empty
  color #5a6b7b

// Lead copy inside a drilldown (e.g. the setup view's connected-count
// summary): quieter than the title, above the main content.
.lti-iframe__lead
  margin 0 0 12px
  color #17212b

// Green check beside the status-view heading: the linked-and-working signal.
.lti-iframe__linked-check
  margin-left 8px
  color #1e7e34
  font-weight 700

// Post-link status list: label/value rows for course link, synced-student
// count, and last sync time.
.lti-status-list
  margin 0
  display flex
  flex-direction column
  gap 8px

.lti-status-list__row
  display flex
  gap 8px

  dt
    font-weight 600
    color #5a6b7b
    min-width 140px

  dd
    margin 0
    color #17212b

.lti-status-list__link
  color #2a5db0

// Reloads the iframe (and with it, kicks a roster sync); quiet action
// beside the last-sync value.
.lti-status-list__refresh
  margin-left 10px
  color #2a5db0
  font-size 13px

.lti-iframe__panel
  display flex
  flex-direction column
  align-items flex-start
  gap 16px

.lti-assignment-roster
  width 100%
  border-collapse collapse
  font-size 14px

  th
    text-align left
    font-weight 600
    color #5a6b7b
    padding 6px 10px
    border-bottom 2px solid #e3e8ee

  td
    padding 8px 10px
    border-bottom 1px solid #eef1f5
    color #17212b
    vertical-align middle

.lti-assignment-roster__link
  color #2a5db0

.lti-status
  display inline-block
  padding 2px 10px
  border-radius 999px
  font-size 12px
  font-weight 600

.lti-status--done
  background #e6f4ea
  color #1e7e34

.lti-status--pending
  background #eef1f5
  color #5a6b7b

// Sandbox actions: the "Show" toggle reveals the lazily-fetched Wikipedia
// content inline; the "Open on Wikipedia" link opens the sandbox in a new tab.
.lti-sandbox__link
  display inline-flex
  align-items center
  gap 4px
  color #2a5db0
  font-size 13px
  text-decoration none

  &:hover
    text-decoration underline

  // The shared external-link icon is a padded background image sized for
  // buttons; shrink and re-center it to sit snugly after this smaller label.
  .icon-z-external-link
    display inline-block
    width 13px
    height 13px
    padding 0
    background-size 11px
    background-position center

.lti-sandbox__toggle
  background none
  border 1px solid #c3cddb
  border-radius 4px
  color #2a5db0
  cursor pointer
  font-size 13px
  padding 2px 10px

.lti-sandbox__toggle[aria-expanded='true']
  background #eef2f8

// In the instructor roster the "Show" toggle is the primary action — revealing
// a student's work inline is the point of the view — so it reads as a filled
// button, while "Open on Wikipedia" stays a quiet secondary link.
.lti-assignment-roster
  .lti-sandbox__toggle
    background #2a5db0
    border-color #2a5db0
    color #fff
    font-weight 600
    padding 4px 14px

    // A caret makes the open/closed state legible at a glance; it points down
    // when collapsed and flips up when this row's preview is showing.
    &::after
      content ''
      display inline-block
      margin-left 8px
      vertical-align middle
      border-left 4px solid transparent
      border-right 4px solid transparent
      border-top 5px solid currentColor
      transition transform .15s ease

    &:hover
      background #244f97
      border-color #244f97

    // Open row: invert to an outlined button and flip the caret, so the one
    // currently showing its preview is unmistakable among the solid closed ones.
    &[aria-expanded='true']
      background #fff
      color #2a5db0

    &[aria-expanded='true']::after
      transform rotate(180deg)

.lti-sandbox__actions
  display flex
  flex-wrap wrap
  align-items center
  gap 12px

.lti-sandbox__detail > td
  padding 12px 16px
  background #fbfcfe

.lti-sandbox__content
  color #5a6b7b
  font-size 13px

.lti-sandbox__content--rendered
  max-height 460px
  overflow-y auto
  padding 16px
  background #fff
  border 1px solid #e3e8ee
  border-radius 6px
  color #17212b
  font-size 14px
  line-height 1.5

  img
    max-width 100%
    height auto

  table
    display block
    max-width 100%
    overflow-x auto
