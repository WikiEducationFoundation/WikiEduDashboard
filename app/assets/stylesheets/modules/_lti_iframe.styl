// Minimal styling for the in-iframe LTI launch views. No navbar/footer.
// White background so the content sits seamlessly inside Canvas's white
// pages — these views render in Canvas iframes, often the small default
// assignment embed, so chrome and spacing stay minimal throughout.
body.lti-iframe
  background #fff
  // Use the brand font, not `inherit` — inherit fell through to the browser
  // default (serif) and made every in-iframe view look like a broken page.
  font-family body-font
  // Belt-and-suspenders against sideways scroll in the narrow Canvas embed;
  // wide tables scroll within their own container instead (see below).
  overflow-x hidden

  *
    box-sizing border-box

// Block, not flex-centered: a flex row made each view a flex item with
// min-width:auto, so content wider than the narrow Canvas iframe overflowed
// sideways (and the vertical centering left short content floating in a tall
// empty frame). Block layout + margin-auto children is responsive and
// top-aligned, which fits the embed.
.lti-iframe__main
  padding 16px

.lti-iframe__landing
  text-align center
  max-width 480px
  margin 0 auto
  padding 24px

.lti-iframe__logo
  display block
  margin 0 auto 28px
  max-width min(260px, 100%)
  max-height 120px
  width auto
  height auto

.lti-iframe__title
  font-size 18px
  font-weight normal
  margin 0 0 24px
  color #333

// Link-state notice on the anonymous landing ("not yet linked"): the
// substantive status line, given slightly more weight than the open-in-new-tab
// hint below it so the actionable message leads.
.lti-iframe__status
  margin 0 0 16px
  color #17212b
  font-size 16px
  font-weight 600

// Quiet "check again" re-launch link on the waiting states (setup pending /
// awaiting approval), so a student can re-check without knowing to reload.
.lti-iframe__check-again
  display inline-block
  margin-top 8px
  color $brand_primary

.lti-iframe__button
  display inline-block

// Option list in the deep-link import picker: one option per row (bare inline
// labels otherwise wrap into a horizontal jumble). Grid keeps the input in its
// own column with the label text aligned beside it.
.lti-deep-link-options
  display flex
  flex-direction column
  gap 10px
  margin 16px 0

  label
    display grid
    grid-template-columns auto 1fr
    column-gap 8px
    align-items baseline
    cursor pointer

// Setup form: "Link this course" is a primary action that only makes sense
// once a course is chosen, so JS disables it until then; dim it and swap the
// cursor so the disabled state clearly reads as "not ready yet".
.lti-setup__submit[disabled]
  opacity .5
  cursor not-allowed

// Shown when the setup POST rejects the chosen course (e.g. it's already linked
// to another Canvas course). The picker normally omits such courses, so this is
// a rare fallback; make it read clearly as an error above the form.
.lti-setup__error
  margin 0 0 18px
  padding 12px 16px
  border-radius 6px
  background #fdecea
  border 1px solid #f5c6c2
  color #8a1c13

// Secondary path for instructors whose course isn't listed yet: a quiet line
// under the form pointing them to their dashboard to set one up.
.lti-setup__alt-path
  margin-top 18px
  color #5a6b7b
  font-size 13px

// Assignment_view drill-down (instructor roster / student panel) and the
// instructor status view. Top-aligned plain content, no card chrome — the
// default Canvas assignment iframe is small, and a bordered/padded card
// wastes enough space to force scrolling.
.lti-iframe__drilldown
  width 100%
  max-width 640px
  margin 0 auto
  text-align left

// Header line: view title left, the bound course's title right (linking
// out to the Dashboard course in a new tab).
.lti-iframe__header
  display flex
  align-items baseline
  justify-content space-between
  gap 12px
  margin 0 0 12px
  padding-bottom 8px
  border-bottom 2px solid #2a5db0

.lti-iframe__drilldown-title
  margin 0
  font-size 18px
  color #17212b

// Small inline external-link icon treatment shared by the quiet links
// (the shared icon class is padded/sized for buttons).
inline-external-icon()
  .icon-z-external-link
    display inline-block
    width 14px
    height 14px
    padding 0
    background-size 12px
    background-position center

.lti-iframe__course-link
  display inline-flex
  align-items center
  gap 6px
  color $brand_primary
  font-size 16px
  font-weight 600
  text-align right
  // Underlined (not color-only) so the link is distinguishable without
  // relying on color — the external-link icon reinforces "opens elsewhere".
  text-decoration underline

  inline-external-icon()

// Wide content (rosters) scrolls within its own container rather than
// forcing the whole embed sideways (body sets overflow-x: hidden).
.lti-table-scroll
  width 100%
  overflow-x auto
  margin 0 0 4px

// Muted placeholder for an empty roster cell (e.g. an anonymized member with
// no Dashboard name) so the row never reads as broken/missing data.
.lti-muted
  color #8a95a3

.lti-iframe__empty
  color #5a6b7b

// Descriptive content rendered live from the Dashboard (block bodies, the
// roll-up's training list): the assignment "description" lives here rather
// than baked into Canvas, so it can't go stale.
.lti-iframe__description
  margin 0 0 16px
  color #17212b
  font-size 14px
  line-height 1.5
  overflow-wrap anywhere

  img
    max-width 100%
    height auto

  // Block bodies are instructor-authored HTML and can contain wide tables;
  // let them scroll within the description rather than overflow the embed.
  table
    display block
    max-width 100%
    overflow-x auto

.lti-trainings-list
  margin 0
  padding 0
  list-style none
  display flex
  flex-direction column
  gap 6px

  .lti-status
    margin-right 8px

// Instructor list: students-completed count after each linked module name.
.lti-trainings-list__count
  margin-left 8px
  color #4a5a6b
  font-size 13px
  white-space nowrap

// When a training is completed, the date sits after the status pill.
.lti-trainings__completed-at
  margin-left 8px
  color #4a5a6b
  font-size 13px
  white-space nowrap

// Lead copy inside a drilldown (e.g. the setup view's connected-count
// summary): quieter than the title, above the main content.
.lti-iframe__lead
  margin 0 0 12px
  color #17212b

// Next-step callout on the status view before any assignment is imported:
// points the instructor at the Modules import path. Reads as a gentle prompt,
// not an error.
.lti-iframe__next-step
  margin 16px 0 0
  padding 14px 16px
  border 1px solid #cdd8ea
  border-left 4px solid $brand_primary
  border-radius 8px
  background #f3f5fb

  h4
    margin 0 0 6px
    color #17212b

  p
    margin 0
    color #3d4757

// Green check beside the status-view heading: the linked-and-working signal.
.lti-iframe__linked-check
  margin-left 8px
  color #1e7e34
  font-weight 700

// Post-link status list: label/value rows for course link, synced-student
// count, and last sync time.
.lti-status-list
  margin 0
  display flex
  flex-direction column
  gap 8px

.lti-status-list__row
  display flex
  gap 8px

  dt
    font-weight 600
    color #5a6b7b
    min-width 140px

  dd
    margin 0
    color #17212b

.lti-status-list__link
  color #2a5db0

// Reloads the iframe (and with it, kicks a roster sync); quiet action
// beside the last-sync value.
.lti-status-list__refresh
  margin-left 10px
  color #2a5db0
  font-size 13px

.lti-iframe__panel
  display flex
  flex-direction column
  align-items flex-start
  gap 16px

// Setup assignment, student branch: the Connected pill with the student's
// username beside it, linking to their Dashboard details view.
.lti-setup-connected
  display flex
  align-items center
  gap 10px
  margin 0

.lti-setup-connected__user
  display inline-flex
  align-items center
  gap 6px
  color #2a5db0

  inline-external-icon()

.lti-assignment-roster
  width 100%
  border-collapse collapse
  font-size 14px

  th
    text-align left
    font-weight 600
    color #5a6b7b
    padding 6px 10px
    border-bottom 2px solid #e3e8ee

  td
    padding 8px 10px
    border-bottom 1px solid #eef1f5
    color #17212b
    vertical-align middle

.lti-assignment-roster__link
  color #2a5db0

.lti-status
  display inline-block
  padding 2px 10px
  border-radius 999px
  font-size 12px
  font-weight 600

.lti-status--done
  background #e6f4ea
  color #1e7e34

// Some progress but not complete (e.g. "3 of 5 trainings"): amber, so a
// partially-done student is unmistakable from both complete (green) and
// not-started (neutral) at a glance.
.lti-status--partial
  background #fdecd6
  color #8a4b06

.lti-status--pending
  background #eef1f5
  color #55606e

// Sandbox actions: the "Show" toggle reveals the lazily-fetched Wikipedia
// content inline; the "Open on Wikipedia" link opens the sandbox in a new tab.
.lti-sandbox__link
  display inline-flex
  align-items center
  gap 4px
  color #2a5db0
  font-size 13px
  text-decoration none

  &:hover
    text-decoration underline

  // The shared external-link icon is a padded background image sized for
  // buttons; shrink and re-center it to sit snugly after this smaller label.
  .icon-z-external-link
    display inline-block
    width 13px
    height 13px
    padding 0
    background-size 11px
    background-position center

.lti-sandbox__toggle
  background none
  border 1px solid #c3cddb
  border-radius 4px
  color #2a5db0
  cursor pointer
  font-size 13px
  padding 2px 10px

.lti-sandbox__toggle[aria-expanded='true']
  background #eef2f8

// In the instructor roster the "Show" toggle is the primary action — revealing
// a student's work inline is the point of the view — so it reads as a filled
// button, while "Open on Wikipedia" stays a quiet secondary link.
.lti-assignment-roster
  .lti-sandbox__toggle
    background #2a5db0
    border-color #2a5db0
    color #fff
    font-weight 600
    padding 4px 14px

    // A caret makes the open/closed state legible at a glance; it points down
    // when collapsed and flips up when this row's preview is showing.
    &::after
      content ''
      display inline-block
      margin-left 8px
      vertical-align middle
      border-left 4px solid transparent
      border-right 4px solid transparent
      border-top 5px solid currentColor
      transition transform .15s ease

    &:hover
      background #244f97
      border-color #244f97

    // Open row: invert to an outlined button and flip the caret, so the one
    // currently showing its preview is unmistakable among the solid closed ones.
    &[aria-expanded='true']
      background #fff
      color #2a5db0

    &[aria-expanded='true']::after
      transform rotate(180deg)

.lti-sandbox__actions
  display flex
  flex-wrap wrap
  align-items center
  gap 12px

.lti-sandbox__detail > td
  padding 12px 16px
  background #fbfcfe

.lti-sandbox__content
  color #5a6b7b
  font-size 13px

.lti-sandbox__content--rendered
  max-height 460px
  overflow-y auto
  padding 16px
  background #fff
  border 1px solid #e3e8ee
  border-radius 6px
  color #17212b
  font-size 14px
  line-height 1.5

  img
    max-width 100%
    height auto

  table
    display block
    max-width 100%
    overflow-x auto
