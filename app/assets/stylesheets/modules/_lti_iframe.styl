// Minimal styling for the in-iframe LTI launch landing page and the
// top-level OAuth-redirect interstitial. No navbar/footer; the layout
// renders a single centered call to action.
body.lti-iframe
  background #f6f6f6
  font-family inherit

.lti-iframe__main
  display flex
  justify-content center
  align-items center
  min-height 100vh
  padding 24px

.lti-iframe__landing
  text-align center
  max-width 480px
  padding 32px 24px

.lti-iframe__logo
  display block
  margin 0 auto 32px
  max-width 260px
  max-height 120px
  width auto
  height auto

.lti-iframe__title
  font-size 18px
  font-weight normal
  margin 0 0 24px
  color #333

.lti-iframe__button
  display inline-block

// Assignment_view drill-down (instructor roster / student panel). Unlike the
// centered landing, this is a top-aligned card that can hold a full roster.
.lti-iframe__drilldown
  align-self flex-start
  width 100%
  max-width 640px
  margin 40px auto
  padding 28px 32px
  background #fff
  border 1px solid #e3e8ee
  border-radius 8px
  box-shadow 0 1px 3px rgba(0, 0, 0, .06)
  text-align left

.lti-iframe__drilldown-title
  margin 0 0 20px
  padding-bottom 14px
  border-bottom 2px solid #2a5db0
  font-size 20px
  color #17212b

.lti-iframe__empty
  color #5a6b7b

.lti-iframe__panel
  display flex
  flex-direction column
  align-items flex-start
  gap 16px

.lti-assignment-roster
  width 100%
  border-collapse collapse
  font-size 14px

  th
    text-align left
    font-weight 600
    color #5a6b7b
    padding 8px 12px
    border-bottom 2px solid #e3e8ee

  td
    padding 10px 12px
    border-bottom 1px solid #eef1f5
    color #17212b
    vertical-align middle

.lti-assignment-roster__link
  color #2a5db0

.lti-status
  display inline-block
  padding 2px 10px
  border-radius 999px
  font-size 12px
  font-weight 600

.lti-status--done
  background #e6f4ea
  color #1e7e34

.lti-status--pending
  background #eef1f5
  color #5a6b7b

// Sandbox actions: the "Show" toggle reveals the lazily-fetched Wikipedia
// content inline; the "Open on Wikipedia" link opens the sandbox in a new tab.
.lti-sandbox__link
  display inline-flex
  align-items center
  gap 4px
  color #2a5db0
  font-size 13px
  text-decoration none

  &:hover
    text-decoration underline

  // The shared external-link icon is a padded background image sized for
  // buttons; shrink and re-center it to sit snugly after this smaller label.
  .icon-z-external-link
    display inline-block
    width 13px
    height 13px
    padding 0
    background-size 11px
    background-position center

.lti-sandbox__toggle
  background none
  border 1px solid #c3cddb
  border-radius 4px
  color #2a5db0
  cursor pointer
  font-size 13px
  padding 2px 10px

.lti-sandbox__toggle[aria-expanded='true']
  background #eef2f8

// In the instructor roster the "Show" toggle is the primary action — revealing
// a student's work inline is the point of the view — so it reads as a filled
// button, while "Open on Wikipedia" stays a quiet secondary link.
.lti-assignment-roster
  .lti-sandbox__toggle
    background #2a5db0
    border-color #2a5db0
    color #fff
    font-weight 600
    padding 4px 14px

    // A caret makes the open/closed state legible at a glance; it points down
    // when collapsed and flips up when this row's preview is showing.
    &::after
      content ''
      display inline-block
      margin-left 8px
      vertical-align middle
      border-left 4px solid transparent
      border-right 4px solid transparent
      border-top 5px solid currentColor
      transition transform .15s ease

    &:hover
      background #244f97
      border-color #244f97

    // Open row: invert to an outlined button and flip the caret, so the one
    // currently showing its preview is unmistakable among the solid closed ones.
    &[aria-expanded='true']
      background #fff
      color #2a5db0

    &[aria-expanded='true']::after
      transform rotate(180deg)

.lti-sandbox__actions
  display flex
  flex-wrap wrap
  align-items center
  gap 12px

.lti-sandbox__detail > td
  padding 12px 16px
  background #fbfcfe

.lti-sandbox__content
  color #5a6b7b
  font-size 13px

.lti-sandbox__content--rendered
  max-height 460px
  overflow-y auto
  padding 16px
  background #fff
  border 1px solid #e3e8ee
  border-radius 6px
  color #17212b
  font-size 14px
  line-height 1.5

  img
    max-width 100%
    height auto

  table
    display block
    max-width 100%
    overflow-x auto
