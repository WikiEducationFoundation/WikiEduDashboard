.vega-graph
  background-color white
  padding 10px
  position fixed
  z-index 1
  top 70px
  left 50%
  min-width 620px
  min-height 440px
  max-width 1200px
  max-height 90vh
  border 1px solid mischka
  border-radius 3px
  box-shadow 0 0 20px 0 rgba(0, 0, 0, .6)
  transform translateX(-50%)

  .radio-row
    margin 8px 0
    text-align center

  .graph-legend
    list-style none
    margin 8px 0 0
    padding 0
    display flex
    flex-wrap wrap
    justify-content center
    gap 4px 16px
    font-size 11px
    color #555

    &__item
      display inline-flex
      align-items center

    &__swatch
      display inline-block
      width 10px
      height 10px
      border-radius 50%
      margin-right 5px

  .scoring-progress
    display flex
    flex-direction column
    align-items center
    justify-content center
    min-height 300px
    padding 0 40px

    &__label
      font-size 13px
      color #555
      margin 0 0 10px

    &__track
      width 70%
      max-width 360px
      height 8px
      background #eee
      border-radius 4px
      overflow hidden
      margin-bottom 14px

    &__fill
      height 100%
      background $brand_primary
      transition-property width
      transition-timing-function linear

  .graph-doc
    margin 16px auto 8px
    max-width 460px
    font-size 11px
    line-height 1.6
    color #555
    text-align left

  .graph-toggle
    display inline-flex
    background #f0f0f0
    border 1px solid #d0d0d0
    border-radius 4px
    overflow hidden
    white-space nowrap
    vertical-align middle

    &__btn
      padding 4px 14px
      font-size 13px
      font-weight 500
      border none
      background transparent
      cursor pointer
      color #666
      transition all 0.2s ease
      line-height 1.4
      &:not(:last-child)
        border-right 1px solid #d0d0d0
      &:hover
        background #e5e5e5
      &.active
        background $brand_primary
        color white

.ores-plot
  padding-top 10px
  padding-bottom 50px
