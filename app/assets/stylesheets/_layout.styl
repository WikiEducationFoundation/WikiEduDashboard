body > .container
  +above(desktop)
    padding-bottom 80px

.container
  center(1100px)
  clearfix()
  padding 0 10px
  position relative
  .container
    padding 0

  // Note: we deliberately keep the 10px inline padding at all viewport
  // widths. Removing it at >=1140px (the prior behaviour) leaves page
  // headers and other inside-container content flush against the
  // window edge at high browser zoom, since zoom does not change the
  // reported viewport width. WCAG 1.4.4 conformance is more important
  // than recovering the 20px of horizontal content area at wide
  // viewports.

  &.narrow
    center(800px)


main
  background-color transparent
  border-width 0 1px
  padding-bottom 80px
  header
    color bayoux
    padding 70px 0 70px

header
  padding 20px
  text-align center
  width 100%
  .title
    padding 0 20px

.wrapper
  min-height 100%
  margin 0 auto -30px

footer
  padding 10
  text-align center
  font-size 65%
  .container
    padding-bottom 10px

.footer, .push
  height 30px

.section-header
  padding 20px 0 20px
  position relative
  clear both
  h3
    color body-color

  .section-header__actions
    //

  +above(tablet)
    padding 15px 0 0

    .section-header__actions
      position absolute
      right 0
      top 20px

  +above(desktop)
    padding 15px 0

  +below(tablet)
    display flex
    flex-direction column
    .controls > button
      font-size 14px
    a
      position relative

// h3 → h2 promotion (for accessible heading hierarchy) made these section
// headers visually larger and changed their color. Preserve the prior h3
// look. Scoped to these specific containers because intentional
// .section-header h2s exist elsewhere (e.g. analytics/usage.html.haml).
.campaign_main.alerts .section-header h2
  color body-color
  font-size 1.563em
#campaign-articles .section-header h2,
#courses .section-header h2
  font-size 1.563em


section
  position relative

.details
  padding-top 20px
  overflow hidden
  text-align left
  span(1)
  .details__detail
    span(1/2)
    padding 20px 0
    text-align left
    +above(desktop)
      span(1/5)
      text-align left
    &:last-child
      span(2/5)
      text-align left
    h6
      font-family body-font
      font-size 15px
    p
      color white
      font-size 15px
      font-weight
      a:hover
        color white

.hidden
  display none !important

.text-center
  text-align center
