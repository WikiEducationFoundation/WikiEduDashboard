# Copy this file to `.env.staging-tests` (which is gitignored) and fill
# in real values. The staging feature-spec runner loads it at start-up.
#
# Required for Tranche 2 (provisioning helpers + provisioning spec).

# Canvas REST API. Generate a token at:
#   canvas.wikiedu.org → Account → Settings → "+ New Access Token"
# under a Canvas user with admin permissions on the test account.
CANVAS_ADMIN_TOKEN=

# Canvas account id under which staging test courses will be provisioned.
# `1` is the root account on a default Canvas install; staging is
# probably the same.
CANVAS_TEST_ACCOUNT_ID=1

# Test identities (Tranche 3+). For each role, the flow specs need:
#   - Canvas user id    (REST API enrolls them in the test course)
#   - Canvas login + password (form-driven login to canvas.wikiedu.org)
#   - Wikipedia username (matches the dashboard `User.username` row)
#   - Wikipedia password (form-driven login during OAuth bounces)
# Login automation runs only when the persistent Chrome profile
# doesn't already carry an active session, so day-to-day reruns stay
# fast; the credentials matter only on first launch and after profile
# resets.
CANVAS_TEST_INSTRUCTOR_USER_ID=
CANVAS_TEST_INSTRUCTOR_LOGIN=
CANVAS_TEST_INSTRUCTOR_PASSWORD=
WIKIPEDIA_TEST_INSTRUCTOR_USERNAME=
WIKIPEDIA_TEST_INSTRUCTOR_PASSWORD=
CANVAS_TEST_STUDENT_USER_ID=
CANVAS_TEST_STUDENT_LOGIN=
CANVAS_TEST_STUDENT_PASSWORD=
WIKIPEDIA_TEST_STUDENT_USERNAME=
WIKIPEDIA_TEST_STUDENT_PASSWORD=

# Dashboard test campaign slug (the slug of a Campaign on
# dashboard-testing that we can attach courses to in order to mark
# them as approved). The Wikipedia Student Program campaign is the
# usual one for Wiki Ed.
DASHBOARD_TEST_CAMPAIGN_SLUG=

# Overrides (defaults shown). Usually no need to set these.
#CANVAS_BASE_URL=https://canvas.wikiedu.org
#STAGING_DASHBOARD_SSH_HOST=dashboard-testing.wikiedu.org
#STAGING_DASHBOARD_SSH_USER=root
