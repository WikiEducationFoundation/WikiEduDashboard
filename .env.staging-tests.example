# Copy this file to `.env.staging-tests` (which is gitignored) and fill
# in real values. The staging feature-spec runner loads it at start-up.
#
# Required for Tranche 2 (provisioning helpers + provisioning spec).

# Canvas REST API. Generate a token at:
#   canvas.wikiedu.org → Account → Settings → "+ New Access Token"
# under a Canvas user with admin permissions on the test account.
CANVAS_ADMIN_TOKEN=

# Canvas account id under which staging test courses will be provisioned.
# `1` is the root account on a default Canvas install; staging is
# probably the same.
CANVAS_TEST_ACCOUNT_ID=1

# Overrides (defaults shown). Usually no need to set these.
#CANVAS_BASE_URL=https://canvas.wikiedu.org
#STAGING_DASHBOARD_SSH_HOST=dashboard-testing.wikiedu.org
#STAGING_DASHBOARD_SSH_USER=root
