#!/usr/bin/env ruby
# frozen_string_literal: true

# Harvest screenshots of the Canvas integration's per-role UX against the
# deployed staging stack (`dashboard-testing.wikiedu.org` ↔ `canvas.wikiedu.org`)
# and assemble a self-contained HTML gallery for review.
#
# Each role is a `:staging` screenshot spec that provisions + tears down its
# own hermetic state; this runner just walks the roles in order, points them
# all at one gitignored run directory via CANVAS_SHOTS_DIR, and builds the
# gallery from whatever landed there.
#
# Usage:
#   bin/harvest-canvas-screenshots [role ...]     # default: every known role
#   HEADLESS=1 bin/harvest-canvas-screenshots      # no visible browser
#   XEPHYR=1 bin/harvest-canvas-screenshots        # visible Chrome in a nested
#                                                  # X window that can't steal
#                                                  # your desktop keyboard focus
#   CANVAS_SHOTS_DIR=/some/dir bin/harvest-canvas-screenshots
#
# Output (gitignored, never committed):
#   tmp/canvas-ux-screenshots/<role>/*.png
#   tmp/canvas-ux-screenshots/gallery.html   # publish as an Artifact; link in the PR
#
# Requires the one-time staging bootstrap (warm Chrome profiles +
# `.env.staging-tests`) — see docs/staging_feature_specs.md. Roles whose env
# vars are missing skip cleanly and simply contribute no screenshots.

require 'base64'
require 'fileutils'

ROOT = File.expand_path('..', __dir__)

# flow => screenshot spec, walked in this order. `admin` is read-only for now
# (the full create->teardown admin walk is a later tranche).
ROLE_SPECS = {
  'instructor'      => 'spec/staging/instructor_setup_screenshots_spec.rb',
  'student'         => 'spec/staging/student_screenshots_spec.rb',
  'active_course'   => 'spec/staging/instructor_active_course_screenshots_spec.rb',
  'canvas_gradebook' => 'spec/staging/canvas_gradebook_screenshots_spec.rb',
  'assignment_view' => 'spec/staging/assignment_view_screenshots_spec.rb',
  'fact_verification' => 'spec/staging/fact_verification_screenshots_spec.rb',
  'full_course'     => 'spec/staging/full_course_screenshots_spec.rb',
  'admin'           => 'spec/staging/admin_setup_screenshots_spec.rb'
}.freeze

# Cool slate neutrals with a single dashboard-blue accent. Section titles and
# captions read as plain language, not slugs/filenames.
GALLERY_CSS = <<~CSS
  :root { --ground:#f6f8fb; --surface:#fff; --ink:#17212b; --muted:#5a6b7b;
          --line:#e3e8ee; --accent:#2a5db0; }
  * { box-sizing: border-box; }
  body { margin:0; background:var(--ground); color:var(--ink); line-height:1.5;
         font-family: system-ui, -apple-system, "Segoe UI", sans-serif; }
  .wrap { max-width:1100px; margin:0 auto; padding:2.5rem 1.5rem 4rem; }
  header.g { border-bottom:2px solid var(--accent); padding-bottom:1rem; margin-bottom:1rem; }
  header.g h1 { margin:0 0 .35rem; font-size:1.6rem; letter-spacing:-.01em; text-wrap:balance; }
  header.g p { margin:0; color:var(--muted); font-size:.95rem; }
  section.role { margin-top:2.75rem; }
  section.role > h2 { margin:0 0 .3rem; font-size:1.15rem; color:var(--accent);
                      letter-spacing:.01em; text-wrap:balance; }
  .blurb { margin:0 0 1.25rem; color:var(--muted); font-size:.95rem; max-width:72ch; }
  .grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(320px, 1fr)); gap:1.25rem; }
  figure { margin:0; background:var(--surface); border:1px solid var(--line);
           border-radius:8px; overflow:hidden; box-shadow:0 1px 3px rgba(20,33,43,.05); }
  figure img { display:block; width:100%; height:auto; border-bottom:1px solid var(--line); }
  figcaption { padding:.6rem .75rem; color:var(--muted); font-size:.85rem; line-height:1.4; }
CSS

