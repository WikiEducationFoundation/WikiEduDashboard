def run_dir
  ENV.fetch('CANVAS_SHOTS_DIR', File.join(ROOT, 'tmp', 'canvas-ux-screenshots'))
end

def roles_to_run
  unknown = ARGV - ROLE_SPECS.keys
  abort "Unknown role(s): #{unknown.join(', ')}. Known: #{ROLE_SPECS.keys.join(', ')}" \
    if unknown.any?
  ARGV.empty? ? ROLE_SPECS.keys : ARGV
end

# Wipe just this role's subdir so the gallery reflects the current run rather
# than accumulating shots from steps that have since been renamed or removed.
def harvest(role)
  spec = ROLE_SPECS.fetch(role)
  dir = File.join(run_dir, role)
  FileUtils.rm_rf(dir)
  warn "\n== Harvesting #{role} (#{spec}) =="
  system({ 'CANVAS_SHOTS_DIR' => run_dir },
         File.join(ROOT, 'bin', 'staging-feature-spec'), spec)
end

def gallery_card(path)
  name = File.basename(path, '.png')
  caption = CAPTIONS.fetch(name, name)
  data = Base64.strict_encode64(File.binread(path))
  %(<figure><img src="data:image/png;base64,#{data}" alt="#{caption}">) +
    %(<figcaption>#{caption}</figcaption></figure>)
end

def gallery_section(section)
  pngs = Dir[File.join(run_dir, section[:role], '*.png')].sort
  return if pngs.empty?

  cards = pngs.map { |p| gallery_card(p) }.join("\n")
  %(<section class="role"><h2>#{section[:title]}</h2>) +
    %(<p class="blurb">#{section[:blurb]}</p>) +
    %(<div class="grid">\n#{cards}\n</div></section>)
end

# Fragment HTML (no <html>/<head>/<body>) so it can be published verbatim as
# an Artifact, while still rendering fine when opened directly in a browser.
def shot_count(roles)
  roles.sum { |r| Dir[File.join(run_dir, r, '*.png')].length }
end

def build_gallery(roles)
  chosen = SECTIONS.select { |s| roles.include?(s[:role]) }
  sections = chosen.filter_map { |s| gallery_section(s) }
  shots = shot_count(roles)
  body = sections.empty? ? '<p>No screenshots captured.</p>' : sections.join("\n")
  html = +"<title>Canvas integration UX</title>\n<style>#{GALLERY_CSS}</style>\n"
  html << gallery_header(shots, sections.length) << body << "\n</div>\n"
  path = File.join(run_dir, 'gallery.html')
  File.write(path, html)
  path
end

def gallery_header(shots, flows)
  %(<div class="wrap">\n<header class="g"><h1>Canvas integration UX</h1>) +
    %(<p>#{shots} screenshot#{'s' unless shots == 1} across ) +
    %(#{flows} flow#{'s' unless flows == 1}, in the order an instructor meets them, ) +
    "from the deployed staging stack.</p></header>\n"
end

# --- Nested-display support (XEPHYR=1) --------------------------------------
# Run the visible browser inside a nested Xephyr X server, so Chrome's window
# raises and focus grabs land on that display instead of the operator's real
# desktop — they can keep typing elsewhere while the harness churns, and only
# click into the nested window to clear a login challenge. No-op under HEADLESS
# (no window at all) or when the flag is unset. The Chrome window size lives in
# spec/staging/spec_helper.rb (1280x900); the nested screen must exceed it.
XEPHYR_SCREEN = '1440x960'

def xephyr_requested?
  !ENV['XEPHYR'].to_s.empty? && ENV['HEADLESS'].to_s.empty?
end

def with_optional_xephyr
  return yield unless xephyr_requested?
  unless system('which', 'Xephyr', out: File::NULL, err: File::NULL)
    warn '  [xephyr] Xephyr not on PATH; running on the normal display.'
    return yield
  end

  display = free_display
  pid = spawn('Xephyr', display, '-screen', XEPHYR_SCREEN, '-resizeable',
              '-no-host-grab', out: File::NULL, err: File::NULL)
  wait_for_x_socket(display)
  ENV['DISPLAY'] = display
  warn "  [xephyr] visible Chrome runs in a nested window on #{display}; focus " \
       'stays there. Click into it only to clear a login challenge.'
  yield
ensure
  terminate(pid)
end

# Lowest display number with no socket in /tmp/.X11-unix yet.
def free_display
  taken = Dir.glob('/tmp/.X11-unix/X*').map { |s| File.basename(s)[1..].to_i }
  n = (1..99).find { |i| !taken.include?(i) } || abort('no free X display')
  ":#{n}"
end

def wait_for_x_socket(display, timeout: 10)
  socket = "/tmp/.X11-unix/X#{display[1..]}"
  deadline = Time.now + timeout
  sleep 0.1 until File.exist?(socket) || Time.now > deadline
  abort "Xephyr #{display} did not start" unless File.exist?(socket)
end

def terminate(pid)
  return unless pid

  Process.kill('TERM', pid)
  Process.wait(pid)
rescue Errno::ESRCH, Errno::ECHILD
  nil # already gone
end

def main
  FileUtils.mkdir_p(run_dir)
  roles = roles_to_run
  results = {}
  with_optional_xephyr { results = roles.to_h { |role| [role, harvest(role)] } }
  gallery = build_gallery(roles)
  warn "\nGallery: #{gallery}"
  failed = results.reject { |_, ok| ok }.keys
  warn "Roles that did not pass cleanly: #{failed.join(', ')}" if failed.any?
  exit(failed.empty? ? 0 : 1)
end

# Guarded so the gallery/helper methods can be required in isolation (e.g. a
# smoke test) without shelling out to a live staging run.
main if $PROGRAM_NAME == __FILE__
