#!/usr/bin/env ruby
# frozen_string_literal: true

# Harvest screenshots of the Canvas integration's per-role UX against the
# deployed staging stack (`dashboard-testing.wikiedu.org` ↔ `canvas.wikiedu.org`)
# and assemble a self-contained HTML gallery for review.
#
# Each role is a `:staging` screenshot spec that provisions + tears down its
# own hermetic state; this runner just walks the roles in order, points them
# all at one gitignored run directory via CANVAS_SHOTS_DIR, and builds the
# gallery from whatever landed there.
#
# Usage:
#   bin/harvest-canvas-screenshots [role ...]     # default: every known role
#   HEADLESS=1 bin/harvest-canvas-screenshots      # no visible browser
#   XEPHYR=1 bin/harvest-canvas-screenshots        # visible Chrome in a nested
#                                                  # X window that can't steal
#                                                  # your desktop keyboard focus
#   CANVAS_SHOTS_DIR=/some/dir bin/harvest-canvas-screenshots
#
# Output (gitignored, never committed):
#   tmp/canvas-ux-screenshots/<role>/*.png
#   tmp/canvas-ux-screenshots/gallery.html   # publish as an Artifact; link in the PR
#
# Requires the one-time staging bootstrap (warm Chrome profiles +
# `.env.staging-tests`) — see docs/staging_feature_specs.md. Roles whose env
# vars are missing skip cleanly and simply contribute no screenshots.

require 'base64'
require 'fileutils'

ROOT = File.expand_path('..', __dir__)

# flow => screenshot spec, walked in this order. `admin` is read-only for now
# (the full create->teardown admin walk is a later tranche).
ROLE_SPECS = {
  'instructor'      => 'spec/staging/instructor_setup_screenshots_spec.rb',
  'student'         => 'spec/staging/student_screenshots_spec.rb',
  'active_course'   => 'spec/staging/instructor_active_course_screenshots_spec.rb',
  'canvas_gradebook' => 'spec/staging/canvas_gradebook_screenshots_spec.rb',
  'assignment_view' => 'spec/staging/assignment_view_screenshots_spec.rb',
  'admin'           => 'spec/staging/admin_setup_screenshots_spec.rb'
}.freeze

# Cool slate neutrals with a single dashboard-blue accent; monospace caption
# labels so the step filenames read as data, not prose.
GALLERY_CSS = <<~CSS
  :root { --ground:#f6f8fb; --surface:#fff; --ink:#17212b; --muted:#5a6b7b;
          --line:#e3e8ee; --accent:#2a5db0; }
  * { box-sizing: border-box; }
  body { margin:0; background:var(--ground); color:var(--ink); line-height:1.5;
         font-family: system-ui, -apple-system, "Segoe UI", sans-serif; }
  .wrap { max-width:1100px; margin:0 auto; padding:2.5rem 1.5rem 4rem; }
  header.g { border-bottom:2px solid var(--accent); padding-bottom:1rem; margin-bottom:1rem; }
  header.g h1 { margin:0 0 .35rem; font-size:1.6rem; letter-spacing:-.01em; text-wrap:balance; }
  header.g p { margin:0; color:var(--muted); font-size:.95rem; }
  section.role { margin-top:2.5rem; }
  section.role > h2 { margin:0 0 1rem; font-size:1.05rem; text-transform:capitalize;
                      color:var(--accent); letter-spacing:.02em; }
  .grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(320px, 1fr)); gap:1.25rem; }
  figure { margin:0; background:var(--surface); border:1px solid var(--line);
           border-radius:8px; overflow:hidden; box-shadow:0 1px 3px rgba(20,33,43,.05); }
  figure img { display:block; width:100%; height:auto; border-bottom:1px solid var(--line); }
  figcaption { padding:.55rem .7rem; color:var(--muted);
               font:.8rem/1.3 ui-monospace, "SF Mono", Menlo, monospace; }
CSS

def run_dir
  ENV.fetch('CANVAS_SHOTS_DIR', File.join(ROOT, 'tmp', 'canvas-ux-screenshots'))
end

def roles_to_run
  unknown = ARGV - ROLE_SPECS.keys
  abort "Unknown role(s): #{unknown.join(', ')}. Known: #{ROLE_SPECS.keys.join(', ')}" if unknown.any?
  ARGV.empty? ? ROLE_SPECS.keys : ARGV
end

# Wipe just this role's subdir so the gallery reflects the current run rather
# than accumulating shots from steps that have since been renamed or removed.
def harvest(role)
  spec = ROLE_SPECS.fetch(role)
  dir = File.join(run_dir, role)
  FileUtils.rm_rf(dir)
  warn "\n== Harvesting #{role} (#{spec}) =="
  system({ 'CANVAS_SHOTS_DIR' => run_dir },
         File.join(ROOT, 'bin', 'staging-feature-spec'), spec)
end

def gallery_card(path)
  name = File.basename(path, '.png')
  data = Base64.strict_encode64(File.binread(path))
  %(<figure><img src="data:image/png;base64,#{data}" alt="#{name}">) +
    %(<figcaption>#{name}</figcaption></figure>)
end

def gallery_section(role)
  pngs = Dir[File.join(run_dir, role, '*.png')].sort
  return if pngs.empty?

  cards = pngs.map { |p| gallery_card(p) }.join("\n")
  %(<section class="role"><h2>#{role.tr('_', ' ')}</h2>) +
    %(<div class="grid">\n#{cards}\n</div></section>)
end

# Fragment HTML (no <html>/<head>/<body>) so it can be published verbatim as
# an Artifact, while still rendering fine when opened directly in a browser.
def build_gallery(roles)
  sections = roles.filter_map { |role| gallery_section(role) }
  shots = roles.sum { |r| Dir[File.join(run_dir, r, '*.png')].length }
  body = sections.empty? ? '<p>No screenshots captured.</p>' : sections.join("\n")
  html = +"<title>Canvas integration UX</title>\n<style>#{GALLERY_CSS}</style>\n"
  html << %(<div class="wrap">\n<header class="g"><h1>Canvas integration UX</h1>)
  html << %(<p>#{shots} screenshot#{'s' unless shots == 1} across )
  html << %(#{sections.length} flow#{'s' unless sections.length == 1}, )
  html << "harvested from the deployed staging stack.</p></header>\n#{body}\n</div>\n"
  path = File.join(run_dir, 'gallery.html')
  File.write(path, html)
  path
end

# --- Nested-display support (XEPHYR=1) --------------------------------------
# Run the visible browser inside a nested Xephyr X server, so Chrome's window
# raises and focus grabs land on that display instead of the operator's real
# desktop — they can keep typing elsewhere while the harness churns, and only
# click into the nested window to clear a login challenge. No-op under HEADLESS
# (no window at all) or when the flag is unset. The Chrome window size lives in
# spec/staging/spec_helper.rb (1280x900); the nested screen must exceed it.
XEPHYR_SCREEN = '1440x960'

def xephyr_requested?
  !ENV['XEPHYR'].to_s.empty? && ENV['HEADLESS'].to_s.empty?
end

def with_optional_xephyr
  return yield unless xephyr_requested?
  unless system('which', 'Xephyr', out: File::NULL, err: File::NULL)
    warn '  [xephyr] Xephyr not on PATH; running on the normal display.'
    return yield
  end

  display = free_display
  pid = spawn('Xephyr', display, '-screen', XEPHYR_SCREEN, '-resizeable',
              '-no-host-grab', out: File::NULL, err: File::NULL)
  wait_for_x_socket(display)
  ENV['DISPLAY'] = display
  warn "  [xephyr] visible Chrome runs in a nested window on #{display}; focus " \
       'stays there. Click into it only to clear a login challenge.'
  yield
ensure
  terminate(pid)
end

# Lowest display number with no socket in /tmp/.X11-unix yet.
def free_display
  taken = Dir.glob('/tmp/.X11-unix/X*').map { |s| File.basename(s)[1..].to_i }
  n = (1..99).find { |i| !taken.include?(i) } || abort('no free X display')
  ":#{n}"
end

def wait_for_x_socket(display, timeout: 10)
  socket = "/tmp/.X11-unix/X#{display[1..]}"
  deadline = Time.now + timeout
  sleep 0.1 until File.exist?(socket) || Time.now > deadline
  abort "Xephyr #{display} did not start" unless File.exist?(socket)
end

def terminate(pid)
  return unless pid

  Process.kill('TERM', pid)
  Process.wait(pid)
rescue Errno::ESRCH, Errno::ECHILD
  nil # already gone
end

def main
  FileUtils.mkdir_p(run_dir)
  roles = roles_to_run
  results = {}
  with_optional_xephyr { results = roles.to_h { |role| [role, harvest(role)] } }
  gallery = build_gallery(roles)
  warn "\nGallery: #{gallery}"
  failed = results.reject { |_, ok| ok }.keys
  warn "Roles that did not pass cleanly: #{failed.join(', ')}" if failed.any?
  exit(failed.empty? ? 0 : 1)
end

# Guarded so the gallery/helper methods can be required in isolation (e.g. a
# smoke test) without shelling out to a live staging run.
main if $PROGRAM_NAME == __FILE__
