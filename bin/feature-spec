#!/usr/bin/env ruby
# frozen_string_literal: true

# Run a feature spec, then print a colored coverage summary for a target file.
#
# Usage:
#   bin/feature-spec <spec_file> [target_file]
#   HEADED=1 bin/feature-spec <spec_file> [target_file]
#
# If target_file is omitted, it is guessed from the spec name:
#   spec/features/foo_spec.rb -> app/controllers/foo_controller.rb

require 'json'

RED    = "\e[31m"
GREEN  = "\e[32m"
YELLOW = "\e[33m"
BOLD   = "\e[1m"
RESET  = "\e[0m"

spec_file = ARGV[0] or abort "Usage: bin/feature-spec <spec_file> [target_file] [rspec_args...]"

remaining = ARGV[1..]
target_file_arg = remaining.find { |a| a.include?('/') || a.end_with?('.rb') }
extra_rspec_args = remaining - [target_file_arg].compact

target_file = target_file_arg || begin
  basename = File.basename(spec_file, '_spec.rb')
  "app/controllers/#{basename}_controller.rb"
end

system('bundle', 'exec', 'rspec', spec_file, *extra_rspec_args, '--format', 'documentation')
rspec_exit = $?.exitstatus

resultset = 'coverage/.resultset.json'
unless File.exist?(resultset)
  warn "#{YELLOW}No coverage data found at #{resultset}#{RESET}"
  exit rspec_exit
end

data = JSON.parse(File.read(resultset))
key  = File.basename(target_file)

lines = nil
data.each_value do |suite|
  suite['coverage']&.each do |path, entry|
    next unless path.end_with?("/#{key}") || path == key
    lines = entry.is_a?(Hash) ? entry['lines'] : entry
    break
  end
  break if lines
end

unless lines
  warn "#{YELLOW}No coverage data found for #{target_file}#{RESET}"
  exit rspec_exit
end

covered   = lines.count { |c| c&.positive? }
uncovered = lines.count { |c| c == 0 }
total     = covered + uncovered
pct       = total > 0 ? (covered.to_f / total * 100).round(1) : 100.0
color     = pct == 100.0 ? GREEN : pct >= 80 ? YELLOW : RED

puts
puts "#{BOLD}Coverage: #{target_file}#{RESET}"
puts "#{color}#{BOLD}#{pct}%#{RESET}  #{color}(#{covered}/#{total} executable lines covered)#{RESET}"

if uncovered > 0
  puts "#{RED}Uncovered lines: #{lines.each_with_index.filter_map { |c, i| i + 1 if c == 0 }.join(', ')}#{RESET}"
end

exit rspec_exit
