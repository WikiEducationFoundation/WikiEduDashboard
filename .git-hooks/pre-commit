#!/bin/bash

# Check for whitespace errors in staged changes
if ! git diff --cached --check > /dev/null 2>&1; then
  echo "Whitespace errors found (trailing whitespace or missing final newline)."
  git diff --cached --check
  exit 1
fi

staged=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rb$')
[ -z "$staged" ] && exit 0

echo "Running RuboCop on staged Ruby files..."
bundle exec rubocop --no-color $staged

if [ $? -ne 0 ]; then
  echo "Linting failed. Please fix the offenses before committing."
  echo "You can run 'bundle exec rubocop -a' to auto-correct some issues."
  exit 1
fi
